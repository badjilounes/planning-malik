# Postgres connection (required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/planning?schema=public"

# API
PORT=3333
NODE_ENV=development

# JWT secrets — replace with strong random values in production
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_REFRESH_TTL="7d"

# Seed user (used by `npm run prisma:seed`)
SEED_USER_EMAIL="demo@planning.app"
SEED_USER_PASSWORD="demo1234"
