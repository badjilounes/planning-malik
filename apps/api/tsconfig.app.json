{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "commonjs",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": false,
    "baseUrl": "../..",
    "paths": {
      "@planning/data-access": ["libs/data-access/src/index.ts"],
      "@planning/types": ["libs/types/src/index.ts"],
      "@planning/utils": ["libs/utils/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/node_modules/**", "**/*.spec.ts", "**/*.test.ts"]
}
